<Window x:Class="ClaudeRtl.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude RTL" Width="468" Height="680"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="#F6F3F0" FontFamily="{StaticResource UiFont}" Foreground="{StaticResource Ink}"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,16,18,16">
    <StackPanel>

      <!-- Header -->
      <StackPanel Orientation="Horizontal" Margin="2,2,0,14">
        <Border Width="46" Height="46" CornerRadius="12" Background="White">
          <Border.Effect><DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.14" /></Border.Effect>
          <Rectangle Width="30" Height="30" Fill="{StaticResource BrandGradient}">
            <Rectangle.OpacityMask><ImageBrush ImageSource="pack://application:,,,/Assets/glyph.png" Stretch="Uniform" /></Rectangle.OpacityMask>
          </Rectangle>
        </Border>
        <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="Claude RTL" FontSize="18" FontWeight="SemiBold" />
          <TextBlock Text="Smooth Hebrew &amp; Arabic for Claude" FontSize="12" Foreground="{StaticResource Muted}" />
        </StackPanel>
      </StackPanel>

      <!-- Status -->
      <Border Style="{StaticResource Card}" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="STATUS" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource Muted}" Margin="0,0,0,9" />
          <TextBlock x:Name="StatusLine" Text="Checking…" FontSize="14.5" FontWeight="SemiBold" />
          <TextBlock x:Name="InstallLine" Text="" FontSize="12" Foreground="{StaticResource Muted}" Margin="0,1,0,11" />

          <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="16" /><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Ellipse x:Name="DotRtl" Width="9" Height="9" Fill="{StaticResource GrayDot}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="RTL" Margin="9,0,0,0" FontSize="12.5" />
            <TextBlock x:Name="ValRtl" Grid.Column="2" Text="-" FontSize="12.5" Foreground="{StaticResource Muted}" />
          </Grid>
          <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="16" /><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Ellipse x:Name="DotCowork" Width="9" Height="9" Fill="{StaticResource GrayDot}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="Cowork" Margin="9,0,0,0" FontSize="12.5" />
            <TextBlock x:Name="ValCowork" Grid.Column="2" Text="-" FontSize="12.5" Foreground="{StaticResource Muted}" />
          </Grid>
          <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="16" /><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Ellipse x:Name="DotAuto" Width="9" Height="9" Fill="{StaticResource GrayDot}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="Auto-update" Margin="9,0,0,0" FontSize="12.5" />
            <TextBlock x:Name="ValAuto" Grid.Column="2" Text="-" FontSize="12.5" Foreground="{StaticResource Muted}" />
          </Grid>

          <Button x:Name="PrimaryBtn" Style="{StaticResource BrandButton}" Margin="0,13,0,0" Content="Re-apply RTL" Click="OnPrimary" />
          <CheckBox x:Name="AutoToggle" Margin="3,12,0,0" FontSize="12.5" Foreground="{StaticResource Ink}"
                    Content="Keep RTL after Claude updates" Click="OnToggle" />
          <TextBlock x:Name="BusyText" Margin="3,9,0,0" FontSize="11.5" Foreground="{StaticResource Brand}" Visibility="Collapsed" Text="Working…" />
          <Button HorizontalAlignment="Left" Style="{StaticResource GhostButton}" Margin="0,9,0,0" Content="Restore original" Click="OnRestore" />
        </StackPanel>
      </Border>

      <!-- Updates -->
      <Border Style="{StaticResource Card}" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="UPDATES" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource Muted}" Margin="0,0,0,9" />
          <Grid>
            <TextBlock x:Name="VersionLine" Text="App version —" FontSize="13" VerticalAlignment="Center" />
            <Button x:Name="CheckBtn" HorizontalAlignment="Right" Style="{StaticResource GhostButton}" Content="Check for updates" Click="OnCheck" />
          </Grid>
          <TextBlock x:Name="UpdateLine" Text="" FontSize="12.5" TextWrapping="Wrap" Margin="0,8,0,0" Visibility="Collapsed" />
          <Border x:Name="NotesBox" Visibility="Collapsed" Margin="0,8,0,0" Background="#F7F5F3" CornerRadius="8" Padding="10" MaxHeight="120">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><TextBlock x:Name="NotesText" FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource Muted}" /></ScrollViewer>
          </Border>
          <Button x:Name="DownloadBtn" Style="{StaticResource BrandButton}" Margin="0,10,0,0" Visibility="Collapsed" Content="Download &amp; Install" Click="OnDownload" />
        </StackPanel>
      </Border>

      <!-- Transparency -->
      <Border Style="{StaticResource Card}" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="WHAT THIS DOES" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource Muted}" Margin="0,0,0,9" />
          <TextBlock FontSize="12.5" TextWrapping="Wrap" Foreground="{StaticResource Ink}" LineHeight="19">
            Claude RTL injects right-to-left support into Claude's interface — the same engine used on macOS and claude.ai. Nothing is sent anywhere; <Run FontWeight="SemiBold">zero telemetry.</Run><LineBreak /><LineBreak />
            On the new <Run FontWeight="SemiBold">MSIX</Run> install, Cowork's service pins Anthropic's certificate on Claude.exe. To keep Cowork working, with your admin approval the patch re-signs Claude.exe with a self-signed certificate, swaps the matching certificate inside cowork-svc.exe, and adds that certificate to your Windows <Run FontWeight="SemiBold">Trusted Root</Run> store (its private key is wiped after signing).<LineBreak /><LineBreak />
            Every original file is backed up first. <Run FontWeight="SemiBold">Restore original</Run> reverts all of it and removes the certificate.
          </TextBlock>
        </StackPanel>
      </Border>

      <!-- Log -->
      <Border Style="{StaticResource Card}">
        <StackPanel>
          <Grid Margin="0,0,0,9">
            <TextBlock Text="LAST OPERATION LOG" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource Muted}" VerticalAlignment="Center" />
            <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}" Content="Refresh" Click="OnRefreshLog" />
          </Grid>
          <Border Background="#1E1E22" CornerRadius="8" Padding="10" Height="128">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
              <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="11" Foreground="#D8D8DC" TextWrapping="Wrap" Text="(no recent operation)" />
            </ScrollViewer>
          </Border>
        </StackPanel>
      </Border>

      <!-- Footer -->
      <Grid Margin="2,12,2,2">
        <Button HorizontalAlignment="Left"  Style="{StaticResource GhostButton}" Content="View on GitHub" Click="OnGitHub" />
        <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}" Content="Quit app" Click="OnQuit" />
      </Grid>

    </StackPanel>
  </ScrollViewer>
</Window>
