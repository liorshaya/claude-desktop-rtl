<Window x:Class="ClaudeRtl.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False" Topmost="True"
        SizeToContent="Height" Width="360"
        FontFamily="{StaticResource UiFont}" Foreground="{StaticResource Ink}"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True"
        Deactivated="OnDeactivated" KeyDown="OnKeyDown">

  <Border Margin="12" CornerRadius="14" Background="{StaticResource CardBg}">
    <Border.Effect>
      <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.20" Color="#000000" />
    </Border.Effect>

    <StackPanel>
      <!-- Header -->
      <Border CornerRadius="14,14,0,0" Background="{StaticResource HeaderBg}" Padding="16,14">
        <StackPanel Orientation="Horizontal">
          <Border Width="46" Height="46" CornerRadius="12" Background="White">
            <Border.Effect><DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.16" /></Border.Effect>
            <Rectangle Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Fill="{StaticResource BrandGradient}">
              <Rectangle.OpacityMask>
                <ImageBrush ImageSource="pack://application:,,,/Assets/glyph.png" Stretch="Uniform" />
              </Rectangle.OpacityMask>
            </Rectangle>
          </Border>
          <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="Claude RTL" FontSize="15.5" FontWeight="SemiBold" />
            <TextBlock Text="Smooth Hebrew &amp; Arabic for Claude" FontSize="11.5" Foreground="{StaticResource Muted}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <StackPanel Margin="16,14,16,16">
        <!-- State badge -->
        <Border x:Name="Badge" CornerRadius="10" Padding="13,11" Background="#F1FAF3"
                BorderBrush="#D8EFDD" BorderThickness="1">
          <StackPanel>
            <TextBlock x:Name="BadgeTitle" Text="Checking..." FontSize="13.5" FontWeight="SemiBold" />
            <TextBlock x:Name="BadgeSub" Text="" FontSize="11.5" Foreground="{StaticResource Muted}" Margin="0,2,0,0" />
          </StackPanel>
        </Border>

        <!-- Health rows -->
        <StackPanel Margin="3,13,3,0">
          <Grid Margin="0,3">
            <Grid.ColumnDefinitions><ColumnDefinition Width="16" /><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Ellipse x:Name="DotRtl" Width="9" Height="9" Fill="{StaticResource GrayDot}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="RTL" Margin="9,0,0,0" FontSize="12.5" />
            <TextBlock x:Name="ValRtl" Grid.Column="2" Text="-" FontSize="12.5" Foreground="{StaticResource Muted}" />
          </Grid>
          <Grid Margin="0,3">
            <Grid.ColumnDefinitions><ColumnDefinition Width="16" /><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Ellipse x:Name="DotCowork" Width="9" Height="9" Fill="{StaticResource GrayDot}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="Cowork" Margin="9,0,0,0" FontSize="12.5" />
            <TextBlock x:Name="ValCowork" Grid.Column="2" Text="-" FontSize="12.5" Foreground="{StaticResource Muted}" />
          </Grid>
          <Grid Margin="0,3">
            <Grid.ColumnDefinitions><ColumnDefinition Width="16" /><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <Ellipse x:Name="DotAuto" Width="9" Height="9" Fill="{StaticResource GrayDot}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="Auto-update" Margin="9,0,0,0" FontSize="12.5" />
            <TextBlock x:Name="ValAuto" Grid.Column="2" Text="-" FontSize="12.5" Foreground="{StaticResource Muted}" />
          </Grid>
        </StackPanel>

        <!-- Primary action -->
        <Button x:Name="PrimaryBtn" Style="{StaticResource BrandButton}" Margin="0,14,0,0"
                Content="Re-apply RTL" Click="OnPrimary" />

        <!-- Auto-update toggle -->
        <CheckBox x:Name="AutoToggle" Margin="3,13,0,0" FontSize="12.5" Foreground="{StaticResource Ink}"
                  Content="Keep RTL after Claude updates" Click="OnToggle" />

        <!-- Busy -->
        <TextBlock x:Name="BusyText" Margin="3,10,0,0" FontSize="11.5" Foreground="{StaticResource Brand}"
                   Visibility="Collapsed" Text="Working..." />

        <Border Height="1" Background="{StaticResource Hairline}" Margin="0,13,0,0" />

        <!-- Footer -->
        <Grid Margin="0,9,0,0">
          <Button HorizontalAlignment="Left"  Style="{StaticResource GhostButton}" Content="Restore original" Click="OnRestore" />
          <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}" Content="Dashboard"        Click="OnDashboard" />
        </Grid>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
