<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AssemblyName>ClaudeRtl</AssemblyName>
    <RootNamespace>ClaudeRtl</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
    <Version>0.2.13</Version>
    <!-- Single-file + WPF + trimming has historical launch-crash bugs (docs/WINDOWS.md sec 6):
         publish single-file WITHOUT trimming. Dev builds stay framework-dependent (fast). -->
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="H.NotifyIcon.Wpf" Version="2.1.0" />
    <PackageReference Include="System.Drawing.Common" Version="8.0.7" />
  </ItemGroup>

  <ItemGroup>
    <!-- The shared brand glyph (Claude starburst + left arrow), reused from the macOS app. -->
    <Resource Include="..\..\assets\claude-rtl-statusTemplate@2x.png" Link="Assets\glyph.png" />
    <Resource Include="Assets\app.ico" />
  </ItemGroup>

</Project>
